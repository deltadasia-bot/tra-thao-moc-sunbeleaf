# ═══════════════════════════════════════════════════
#  SUNBELEAF BACKEND – Biến môi trường
#  Sao chép file này thành .env và điền giá trị thật
# ═══════════════════════════════════════════════════

# ── Cổng server ─────────────────────────────────────
PORT=3000

# ── CORS ────────────────────────────────────────────
# Danh sách domain Mini App được phép gọi API
ALLOWED_ORIGINS=https://miniapp.zalo.me,http://localhost:3001


# ══════════════════════════════════════════════════════
#  SEPAY – Nhận webhook khi ACB nhận chuyển khoản
#  Đăng ký tại: https://sepay.vn → Cài đặt → API Key
# ══════════════════════════════════════════════════════
SEPAY_API_KEY=your_sepay_api_key_here
BANK_NAME=ACB
BANK_ACCOUNT_NUMBER=34931868
BANK_ACCOUNT_NAME=CÔNG TY TNHH THỰC PHẨM DELTA D'ASIA


# ══════════════════════════════════════════════════════
#  ZALO CHECKOUT CDK – Ký MAC cho ZaloPay/MoMo
#  Lấy tại: Zalo Mini App Console → App → Payment Settings
# ══════════════════════════════════════════════════════
ZALO_APP_SECRET=your_zalo_app_secret_here
ZALO_APP_ID=your_zalo_app_id_here


# ══════════════════════════════════════════════════════
#  SAPO – Đồng bộ đơn hàng vào Sapo để quản lý
#
#  Cách lấy thông tin:
#   1. Đăng nhập Sapo Admin (https://{store}.mysapo.net/admin)
#   2. Vào: Cài đặt → Ứng dụng → Ứng dụng riêng → Tạo ứng dụng
#   3. Chọn quyền: Orders (đọc + ghi)
#   4. Bấm Tạo → Copy "API key" và "Password"
# ══════════════════════════════════════════════════════
SAPO_STORE=sunbeleaf        # Tên store (phần trước .mysapo.net)
SAPO_API_KEY=               # API key từ private app
SAPO_PASSWORD=              # Password từ private app


# ══════════════════════════════════════════════════════
#  THÔNG BÁO EMAIL – Gửi email khi có đơn hàng mới
#
#  Cách lấy Gmail App Password:
#   1. Vào: myaccount.google.com → Security → 2-Step Verification (bật nếu chưa)
#   2. Tìm "App passwords" (Mật khẩu ứng dụng)
#   3. Chọn: Mail + Other → đặt tên "Sunbeleaf" → Generate
#   4. Copy mật khẩu 16 ký tự (dạng: xxxx xxxx xxxx xxxx)
# ══════════════════════════════════════════════════════
# Nhanh.vn - dong bo don hang tu Zalo Mini App sang Nhanh.vn
# Tai lieu: https://apidocs.nhanh.vn/v3
# Lay appId, businessId, accessToken tai trang ung dung Nhanh.vn.
# NHANH_PRODUCT_MAP dung de map productId noi bo -> ID san pham tren Nhanh.vn.
# Vi du: {"1":1231281071,"1:Tui 25 goi":1231281071,"1:Tui 50 goi":1231281072,"999001":1231281099}
NHANH_API_BASE=https://pos.open.nhanh.vn/v3.0
NHANH_APP_ID=
NHANH_SECRET_KEY=
NHANH_BUSINESS_ID=
NHANH_ACCESS_TOKEN=
NHANH_WEBHOOK_VERIFY_TOKEN=SunbeleafNhanhWebhook2026
NHANH_SOURCE_NAME=Zalo Mini App Sunbeleaf
NHANH_DEPOT_ID=
NHANH_SALE_ID=
NHANH_CREATED_BY_ID=
NHANH_TRANSFER_ACCOUNT_ID=
NHANH_PRODUCT_MAP={}

NOTIFY_EMAIL_FROM=deltadasia@gmail.com
NOTIFY_EMAIL_PASS=                     # App Password 16 ký tự (không có dấu cách)
NOTIFY_EMAIL_TO=deltadasia@gmail.com   # Email nhận thông báo


# ══════════════════════════════════════════════════════
#  THÔNG BÁO ZALO OA – Gửi tin nhắn Zalo khi có đơn
#
#  Cách thiết lập (khoảng 10 phút):
#   1. Tạo Official Account miễn phí tại: https://oa.zalo.me
#      → Chọn loại: "Doanh nghiệp/Cá nhân kinh doanh"
#   2. Dùng số 0903349318 follow OA vừa tạo trên Zalo
#   3. Vào OA Admin → Phát triển → Quản lý API
#      → Bật "Gửi tin nhắn đến người dùng"
#      → Copy "Access Token" và "Refresh Token"
#   4. Vào OA Admin → Thành viên → tìm tài khoản 0903349318
#      → Copy "Zalo User ID" (dãy số)
#   5. Điền các giá trị dưới đây
# ══════════════════════════════════════════════════════
ZALO_OA_ACCESS_TOKEN=       # Lấy từ OA Admin → Phát triển → API
ZALO_OA_REFRESH_TOKEN=      # Để tự động gia hạn khi hết hạn
ZALO_OA_APP_ID=             # App ID của OA
ZALO_OA_APP_SECRET=         # App Secret của OA
ZALO_OWNER_USER_ID=         # Zalo User ID của 0903349318 (lấy từ mục Thành viên)


# Admin dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=doi-mat-khau-manh-o-day
ADMIN_SESSION_SECRET=tao-chuoi-bi-mat-dai-toi-thieu-32-ky-tu
ADMIN_RECOVERY_PHONE=0903349318
ADMIN_SESSION_TTL_MS=28800000
ADMIN_OTP_TTL_MS=600000
