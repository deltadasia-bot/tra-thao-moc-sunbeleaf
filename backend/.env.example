# ============================================================
# SUNBELEAF BACKEND - Environment template
# Copy this file to .env and fill real values locally/Railway.
# Do not commit backend/.env to git.
# ============================================================

# Server
PORT=3000

# CORS - comma separated origins allowed to call backend APIs
ALLOWED_ORIGINS=https://miniapp.zalo.me,http://localhost:3001


# Public backend URL used when uploaded media falls back to backend storage.
PUBLIC_BACKEND_URL=https://tra-thao-moc-sunbeleaf-production.up.railway.app


# ============================================================
# Product media upload
# If WordPress credentials are filled, admin uploads go to WordPress Media.
# If left empty, files are stored on backend and served from PUBLIC_BACKEND_URL.
# ============================================================
WORDPRESS_MEDIA_URL=https://deltadasia.com/wp-json/wp/v2/media
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
PRODUCT_MEDIA_MAX_MB=80


# ============================================================
# Sepay / ACB bank transfer webhook
# ============================================================
SEPAY_API_KEY=your_sepay_api_key_here
BANK_NAME=ACB
BANK_ACCOUNT_NUMBER=34931868
BANK_ACCOUNT_NAME=CONG TY TNHH THUC PHAM DELTA D'ASIA


# ============================================================
# Zalo Checkout SDK / payment callback
# ============================================================
ZALO_APP_SECRET=your_zalo_app_secret_here
ZALO_APP_ID=your_zalo_app_id_here
ZALO_CALLBACK_KEY=your_zalo_callback_key_here


# ============================================================
# Sapo integration
# Private app fields are legacy/fallback.
# OAuth fields are used by the current partner app flow.
# ============================================================
SAPO_STORE=sunbeleaf
SAPO_API_KEY=
SAPO_SECRET_KEY=
SAPO_PASSWORD=
SAPO_REDIRECT_URI=https://tra-thao-moc-sunbeleaf-production.up.railway.app/api/sapo/oauth/callback
SAPO_ACCESS_TOKEN=


# ============================================================
# Nhanh.vn integration
# Docs: https://apidocs.nhanh.vn/v3
# NHANH_PRODUCT_MAP maps mini-app product IDs/variants to Nhanh product IDs.
# Example: {"1":1231281071,"1:Tui 25 goi":1231281071,"1:Tui 50 goi":1231281072}
# ============================================================
NHANH_API_BASE=https://pos.open.nhanh.vn/v3.0
NHANH_APP_ID=
NHANH_SECRET_KEY=
NHANH_REDIRECT_URI=https://tra-thao-moc-sunbeleaf-production.up.railway.app/api/nhanh/oauth/callback
NHANH_BUSINESS_ID=
NHANH_ACCESS_TOKEN=
NHANH_WEBHOOK_VERIFY_TOKEN=SunbeleafNhanhWebhook2026
NHANH_SOURCE_NAME=Zalo Mini App Sunbeleaf
NHANH_DEPOT_ID=
NHANH_SALE_ID=
NHANH_CREATED_BY_ID=
NHANH_TRANSFER_ACCOUNT_ID=
NHANH_PRODUCT_MAP={}


# ============================================================
# Email notification
# Use Gmail App Password, not the normal Gmail password.
# ============================================================
NOTIFY_EMAIL_FROM=deltadasia@gmail.com
NOTIFY_EMAIL_PASS=
NOTIFY_EMAIL_TO=deltadasia@gmail.com


# ============================================================
# Zalo OA notification
# ============================================================
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
ZALO_OWNER_USER_ID=


# ============================================================
# Admin dashboard
# ============================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=create-a-secret-at-least-32-characters-long
ADMIN_RECOVERY_PHONE=0903349318
ADMIN_SESSION_TTL_MS=28800000
ADMIN_OTP_TTL_MS=600000
